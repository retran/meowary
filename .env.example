# Environment variables for Meowary
#
# OpenCode reads credentials from the shell environment, not from this file
# directly. mise loads this file automatically when you enter the directory
# (after running `mise trust` once). direnv works too: add `dotenv` to .envrc.
#
# Never commit .env — it is listed in .gitignore.

# ── Atlassian identity ────────────────────────────────────────────────────────
# One email and one API token. All three tool groups below reference the same
# values — setup.sh writes them automatically when you run it.
ATLASSIAN_EMAIL=you@example.com
ATLASSIAN_API_TOKEN=your-atlassian-api-token
ATLASSIAN_INSTANCE=your-instance.atlassian.net

# ── Scripts group ─────────────────────────────────────────────────────────────
# Used by .opencode/scripts/config.js for direct Atlassian REST API calls.
ATLASSIAN_USERNAME=${ATLASSIAN_EMAIL}
CONFLUENCE_URL=https://${ATLASSIAN_INSTANCE}/wiki
JIRA_URL=https://${ATLASSIAN_INSTANCE}
CONFLUENCE_SPACES="ENG TEAM"

# ── confluence-cli ────────────────────────────────────────────────────────────
# Install: npm install -g confluence-cli
CONFLUENCE_DOMAIN=${ATLASSIAN_INSTANCE}
CONFLUENCE_EMAIL=${ATLASSIAN_EMAIL}
CONFLUENCE_API_TOKEN=${ATLASSIAN_API_TOKEN}
CONFLUENCE_API_PATH=/wiki/rest/api
CONFLUENCE_READ_ONLY=true

# ── jira CLI ──────────────────────────────────────────────────────────────────
# Install: brew install jira-cli
# One-time setup: run `jira init` interactively after .env is loaded.
JIRA_API_TOKEN=${ATLASSIAN_API_TOKEN}

# ── OpenCode built-ins ────────────────────────────────────────────────────────
OPENCODE_ENABLE_EXA=1
OPENCODE_EXPERIMENTAL_LSP_TOOL=true

# ── ctx7 (optional) ───────────────────────────────────────────────────────────
# Context7 library docs. Run via: npx ctx7 docs <library-id> "<query>"
# API key is optional — without it, public rate limits apply.
CONTEXT7_API_KEY=
