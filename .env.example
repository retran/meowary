# Environment variables for Meowary
#
# OpenCode reads credentials from the shell environment, not from this file
# directly. Use direnv or mise to load these variables automatically when you
# enter the directory.
#
# direnv:  copy to .env, then add `dotenv` to your .envrc
# mise:    copy to .env, mise will pick it up automatically
#
# Never commit .env — it is listed in .gitignore.

# ── Scripts group ────────────────────────────────────────────────────────────
# Used by scripts/config.js for direct Confluence REST API calls.
# NOT used by the confluence-cli or jira CLI tools — those use their own vars below.
ATLASSIAN_USERNAME=you@example.com
ATLASSIAN_API_TOKEN=your-atlassian-api-token
CONFLUENCE_URL=https://your-instance.atlassian.net/wiki
JIRA_URL=https://your-instance.atlassian.net
CONFLUENCE_SPACES=ENG TEAM

# ── confluence-cli ───────────────────────────────────────────────────────────
# Install: npm install -g confluence-cli
# CONFLUENCE_API_TOKEN here is the same Atlassian token value as ATLASSIAN_API_TOKEN above.
# They are separate variables — set both to the same token.
CONFLUENCE_DOMAIN=your-instance.atlassian.net
CONFLUENCE_EMAIL=you@example.com
CONFLUENCE_API_TOKEN=your-atlassian-api-token
CONFLUENCE_API_PATH=/wiki/rest/api
CONFLUENCE_READ_ONLY=true

# ── jira CLI ─────────────────────────────────────────────────────────────────
# Install: brew install ankitpokhrel/tap/jira-cli
# One-time setup: run `jira init` interactively — generates ~/.config/.jira/.config.yml
# JIRA_API_TOKEN is the same Atlassian token value as ATLASSIAN_API_TOKEN above.
JIRA_API_TOKEN=your-atlassian-api-token

# ── OpenCode built-ins ───────────────────────────────────────────────────────
# Enable built-in Exa web search (no API key required).
OPENCODE_ENABLE_EXA=1
# Enable experimental LSP tool (requires the lsp permission in opencode.json).
OPENCODE_EXPERIMENTAL_LSP_TOOL=true

# ── ctx7 ─────────────────────────────────────────────────────────────────────
# Context7 library docs CLI. Run via: npx ctx7 docs <library-id> "<query>"
# API key is optional — without it, public rate limits apply.
CONTEXT7_API_KEY=
