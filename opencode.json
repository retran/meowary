{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "context/*.md"
  ],
  "plugin": [
    "@franlol/opencode-md-table-formatter@latest",
    "@tarquinen/opencode-dcp@latest"
  ],
  "permission": {
    "bash": "allow",
    "websearch": "allow",
    "lsp": "allow",
    "external_directory": {
      "~/workspace/**": "allow"
    }
  }
}
