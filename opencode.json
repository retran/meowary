{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    ".opencode/plugin/shell-strategy/shell_strategy.md"
  ],
  "plugin": [
    "@franlol/opencode-md-table-formatter@latest",
    "@tarquinen/opencode-dcp@latest"
  ],
  "mcp": {
    "atlassian": {
      "type": "local",
      "command": ["uvx", "mcp-atlassian"],
      "environment": {
        "CONFLUENCE_URL": "{env:CONFLUENCE_URL}",
        "CONFLUENCE_USERNAME": "{env:ATLASSIAN_USERNAME}",
        "CONFLUENCE_API_TOKEN": "{env:ATLASSIAN_API_TOKEN}",
        "JIRA_URL": "{env:JIRA_URL}",
        "JIRA_USERNAME": "{env:ATLASSIAN_USERNAME}",
        "JIRA_API_TOKEN": "{env:ATLASSIAN_API_TOKEN}"
      }
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    }
  },
  "permission": {
    "bash": "allow",
    "external_directory": {
      "~/workspace/**": "allow"
    }
  },
  "_comment_external_directory": "Set the path above to the directory where your source code repositories live. {env:VAR} is not supported in permission keys — edit the path directly."
}
